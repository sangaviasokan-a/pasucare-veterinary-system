generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

model Service {
  id          String @id @default(cuid())
  title       String
  description String?
  duration    Int
  active      Boolean @default(true)

  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id String @id @default(cuid())

  fullName String
  phone String

  serviceId String
  service Service @relation(fields: [serviceId], references: [id])

  startTime DateTime
  endTime DateTime

  status AppointmentStatus @default(PENDING)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Availability {
  id String @id @default(cuid())

  dayOfWeek Int

  startTime String
  endTime String

  enabled Boolean @default(true)
}

model Notification {
  id String @id @default(cuid())

  title String
  message String

  read Boolean @default(false)

  createdAt DateTime @default(now())
}